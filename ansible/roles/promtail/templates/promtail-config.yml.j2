server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ promtail_loki_push_url }}

scrape_configs:

  - job_name: nginx
    static_configs:
      - targets:
          - localhost
        labels:
          job: nginx
          app: nginx
          env: prod
          host: "{{ inventory_hostname }}"
          __path__: /var/log/nginx/*.log

    pipeline_stages:
      - json:
          expressions:
            time: time
            remote_addr: remote_addr
            method: method
            uri: uri
            status: status

  - job_name: app
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s

    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/bulletin-board'
        action: keep

      - source_labels: ['__meta_docker_container_name']
        target_label: 'container'

      - target_label: job
        replacement: app

      - target_label: app
        replacement: bulletin-board

      - target_label: env
        replacement: prod

      - target_label: host
        replacement: "dobro10k2"
