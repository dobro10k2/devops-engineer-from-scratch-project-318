global:
  scrape_interval: 15s

rule_files:
  - "alerts.yml"

scrape_configs:

  - job_name: node_exporter
    static_configs:
      - targets:
{% for target in prometheus_targets.node_exporter %}
        - "{{ target }}"
{% endfor %}

  - job_name: application
    metrics_path: /actuator/prometheus
    static_configs:
      - targets:
{% for target in prometheus_targets.application %}
        - "{{ target }}"
{% endfor %}
